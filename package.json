{
  "name": "azion",
  "version": "0.0.1",
  "description": "Azion Packages for Edge Computing.",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "compile": "pnpm -r --if-present compile",
    "lint": "pnpm -r --if-present lint",
    "lint:fix": "pnpm -r --if-present lint:fix",
    "format": "pnpm -r --if-present prettier",
    "format:check": "pnpm -r --if-present prettier:check",
    "test": "pnpm -r --if-present test ./packages/*",
    "test:e2e": "npx jest ./tests/e2e/*",
    "download:cli": "node ./cli/scripts/download-cli.mjs",
    "build": "pnpm -r --if-present compile"
  },
  "keywords": [
    "azion",
    "edge",
    "computing",
    "packages"
  ],
  "author": "aziontech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aziontech/lib.git"
  },
  "contributors": [
    {
      "name": "José Filho",
      "url": "https://github.com/jcsbfilho"
    },
    {
      "name": "Magnun A V F",
      "url": "https://github.com/MagnunAVFAzion"
    },
    {
      "name": "João Narciso",
      "url": "https://jotanarciso.com"
    }
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.29.2",
    "pkg-pr-new": "^0.0.60",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.36.0",
    "@types/eslint__js": "^8.42.3",
    "conventional-changelog-conventionalcommits": "^4.6.0",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.44.1",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "README.md",
    "package.json",
    "packages/**/dist/**/*",
    "cli/**/*",
    "packages/unenv-preset/src/polyfills/*",
    "packages/bundler/src/polyfills/*",
    "packages/presets/src/presets/next/*",
    "packages/presets/src/presets/nuxt/nitro/*",
    "packages/presets/src/presets/svelte/kit/*"
  ]
}
